{
  "rules": {
    "jobs": {
      ".read": true,
      "$jobId": {
        ".write": "auth != null && (!data.exists() || data.child('user').val() === auth.uid || auth.uid === 'GrajEM98vOc1w3FUr9XeTN90rfl2')"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || auth.uid === 'GrajEM98vOc1w3FUr9XeTN90rfl2'"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}

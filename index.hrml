<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JobMarket Cameroon 🇨🇲</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css"/>

<style>
:root { --gold:#f59e0b; --dark:#0f172a; --green:#10b981; --wa:#25D366; }
body, html { margin:0; height:100%; width:100%; overflow:hidden; font-family:sans-serif; background:#000; }
#map { position:absolute; top:0; bottom:0; width:100%; }

.btn { position:absolute; right:15px; width:45px; height:45px; background:white; border-radius:12px; display:flex; align-items:center; justify-content:center; z-index:1000; border:none; font-size:20px; }
#gps { top:20px; }
#add { position:absolute; bottom:90px; right:20px; width:65px; height:65px; border-radius:50%; background:var(--gold); color:white; font-size:35px; border:none; z-index:1000; }

.panel { position:fixed; bottom:-100%; left:0; width:100%; background:var(--dark); color:white; padding:20px; transition:.4s; z-index:2000; border-radius:25px 25px 0 0; }
.panel.active { bottom:0; }

input, textarea { width:100%; padding:14px; margin:8px 0; background:#1e293b; border:1px solid #334155; color:white; border-radius:10px; }

.ai-msg { background:#1e293b; padding:15px; border-radius:12px; margin-top:15px; border-left:5px solid var(--green); }

#bottomNav { position:absolute; bottom:0; width:100%; background:white; display:flex; height:70px; justify-content:space-around; align-items:center; }
.nav-btn { text-align:center; font-size:11px; flex:1; border:none; background:none; }
</style>
</head>

<body>

<div id="map"></div>

<button id="gps" class="btn" onclick="centerUser()">🎯</button>
<button id="add" onclick="togglePanel('panel')">+</button>

<!-- PANEL POST -->
<div id="panel" class="panel">
<h3 style="text-align:center;color:var(--gold)">Publier un Job 🇨🇲</h3>
<input id="title" placeholder="Métier">
<input id="phone" placeholder="WhatsApp">
<textarea id="desc" placeholder="Services"></textarea>
<button onclick="publish()" style="width:100%;background:var(--gold);color:white;padding:15px;border:none;border-radius:10px;">PUBLIER</button>
</div>

<!-- PANEL IA -->
<div id="businessPanel" class="panel" style="border-top:4px solid var(--green)">
<h3 style="text-align:center;color:var(--green)">💰 Coach Business</h3>
<input id="ai-q" placeholder="Pose ta question">
<button onclick="askAI()" style="width:100%;background:var(--green);color:white;padding:15px;border:none;border-radius:10px;">DEMANDER</button>
<div id="ai-res" class="ai-msg">Le coach attend...</div>
</div>

<div id="bottomNav">
<button class="nav-btn" onclick="togglePanel('panel')">POSTER</button>
<button class="nav-btn" onclick="location.reload()">CARTE</button>
<button class="nav-btn" onclick="togglePanel('businessPanel')">IA</button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.1.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.1.1/firebase-database-compat.js"></script>

<script>
// FIREBASE
const firebaseConfig = {
  apiKey: "AIzaSy...",
  authDomain: "jobmarketfuture.firebaseapp.com",
  databaseURL: "https://jobmarketfuture-default-rtdb.firebaseio.com",
  projectId: "jobmarketfuture"
};
firebase.initializeApp(firebaseConfig);
const db = firebase.database();

let map, userMarker, userPos=null;

// INIT MAP
window.onload = function(){
    map = L.map('map').setView([3.86,11.51],13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    navigator.geolocation.watchPosition(pos=>{
        userPos=[pos.coords.latitude,pos.coords.longitude];
        if(!userMarker){
            userMarker=L.circleMarker(userPos).addTo(map);
            map.setView(userPos,14);
        } else userMarker.setLatLng(userPos);
    });

    loadJobs();
};

// UI
function togglePanel(id){
    document.getElementById(id).classList.toggle("active");
}

// PUBLISH
function publish(){
    let t=title.value,p=phone.value,d=desc.value;
    if(!t||!p) return alert("Champs requis");
    db.ref("jobs").push({title:t,phone:p,desc:d,lat:map.getCenter().lat,lng:map.getCenter().lng});
    togglePanel('panel');
}

// LOAD
function loadJobs(){
    db.ref("jobs").on("value",snap=>{
        map.eachLayer(l=>{ if(l instanceof L.Marker) map.removeLayer(l); });
        snap.forEach(c=>{
            let d=c.val();
            L.marker([d.lat,d.lng]).addTo(map)
            .bindPopup(`<b>${d.title}</b><br>${d.desc}<br><a href="https://wa.me/${d.phone}" target="_blank">WhatsApp</a>`);
        });
    });
}

// IA FINAL
async function askAI(){
    const q=ai-q.value;
    const res=document.getElementById("ai-res");
    if(!q) return;

    res.innerHTML="⌛ Analyse...";

    try{
        const response = await fetch("https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash:generateContent?key=TA_CLE",{
            method:"POST",
            headers:{ "Content-Type":"application/json" },
            body:JSON.stringify({
                contents:[{parts:[{text:"Réponds en 2 phrases max avec prix en FCFA: "+q}]}]
            })
        });

        const data = await response.json();

        if(data.candidates && data.candidates.length>0){
            res.innerHTML = "<b>💰 Conseil :</b><br>"+data.candidates[0].content.parts[0].text;
        } else {
            res.innerHTML="⚠️ Pas de réponse";
        }

    }catch(e){
        res.innerHTML="❌ Erreur réseau";
    }
}

function centerUser(){ if(userPos) map.setView(userPos,16); }
</script>

</body>
</html>

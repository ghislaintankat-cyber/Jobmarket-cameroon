<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobMarket Cameroun</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; background: #0f172a; color: white; font-family: sans-serif; }
        #app { display: flex; flex-direction: column; height: 100vh; }
        header { padding: 15px; background: #1e293b; text-align: center; border-bottom: 2px solid #06b6d4; }
        #map { flex-grow: 1; background: #222; }
        .footer { padding: 15px; background: #0f172a; }
        .btn { background: #06b6d4; color: #0f172a; border: none; padding: 15px; border-radius: 10px; font-weight: bold; width: 100%; cursor: pointer; font-size: 1rem; }
        #formModal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 2000; justify-content: center; align-items: center; }
        .modal-content { background: #1e293b; padding: 20px; border-radius: 15px; width: 85%; max-width: 400px; }
        input, textarea, select { width: 100%; margin-bottom: 10px; padding: 10px; border-radius: 5px; border: none; box-sizing: border-box; }
    </style>
</head>
<body>

<div id="app">
    <header><b>JOBMARKET CAMEROUN 🛰️</b></header>
    <div id="map"></div>
    <div class="footer">
        <button class="btn" onclick="document.getElementById('formModal').style.display='flex'">🚀 PUBLIER UNE MISSION</button>
    </div>
</div>

<div id="formModal">
    <div class="modal-content">
        <h3>Nouvelle Annonce</h3>
        <select id="mType"><option>🛠️ Dépannage</option><option>📦 Livraison</option><option>🧹 Ménage</option></select>
        <input type="text" id="userName" placeholder="Ton nom">
        <input type="number" id="userPhone" placeholder="WhatsApp (9 chiffres)">
        <textarea id="mDesc" placeholder="Description et Prix"></textarea>
        <input type="password" id="delCode" placeholder="Code secret">
        <button class="btn" onclick="publier()">VALIDER LA PUBLICATION</button>
        <button class="btn" style="background:gray; margin-top:5px;" onclick="document.getElementById('formModal').style.display='none'">Annuler</button>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getDatabase, ref, push, onChildAdded } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

  const firebaseConfig = {
    apiKey: "AIzaSyCR1Z6VlS5A7iPbUCoVm0AQcnkkUdsA0CE",
    authDomain: "jobmarketfuture.firebaseapp.com",
    databaseURL: "https://jobmarketfuture-default-rtdb.firebaseio.com",
    projectId: "jobmarketfuture",
    storageBucket: "jobmarketfuture.firebasestorage.app",
    messagingSenderId: "351669024349",
    appId: "1:351669024349:web:d4d4d08727ccc6012b7fb4"
  };

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);
  const missionsRef = ref(db, 'missions');

  // CARTE
  var map = L.map('map').setView([3.848, 11.502], 13);
  
  // Utilisation d'une carte standard (plus rapide à charger que le satellite)
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

  // Correction affichage mobile
  setTimeout(() => { map.invalidateSize(); }, 1000);

  window.publier = function() {
    const data = {
        type: document.getElementById('mType').value,
        name: document.getElementById('userName').value || "Anonyme",
        phone: document.getElementById('userPhone').value,
        desc: document.getElementById('mDesc').value,
        code: document.getElementById('delCode').value
    };

    if(!data.phone || !data.desc) return alert("Remplis les infos !");

    // DEMANDE GPS
    map.locate({setView: true, maxZoom: 16});
    
    map.on('locationfound', (e) => {
        data.lat = e.latlng.lat;
        data.lng = e.latlng.lng;
        push(missionsRef, data).then(() => { 
            alert("✅ Publié avec succès !"); 
            location.reload(); 
        });
    });

    map.on('locationerror', () => {
        alert("Erreur : Active ton GPS et autorise le site !");
    });
  };

  onChildAdded(missionsRef, (snap) => {
    const m = snap.val();
    L.marker([m.lat, m.lng]).addTo(map)
     .bindPopup(`<b>${m.type}</b><br>${m.desc}<br>WA: ${m.phone}`);
  });
</script>
</body>
</html>
